<?xml version="1.0"?>

<robot name="EXCAVATOR_CONEXPO" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- 
Cordinate frame definition
Marked ||  (Link)   |        |  (Link)
Point  ||  Parent   | Joint  |  Child 
==========================================
    Z  || cs_ground | origin | base_link 
    O  || base_link | swing  | cs_cor 
    A  || cs_cor    | boom   | cs_boom 
    D  || cs_boom   | arm    | cs_arm 
    I  || cs_arm    | bucket | cs_bucket 
       || cs_bucket | tilt   | cs_tilt 
       || cs_tilt   | rotate | cs_rotate 
       || cs_rotate | tip    | cs_tip1 
-->

<!-- Predefine Colors -->
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>

    <material name="dark">
        <color rgba="0.2 0.2 0.2 1.0"/>
    </material>

    <material name="dark_grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
    </material>

    <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
    </material>

    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
    </material>

    <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
    </material>

    <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
    </material>

    <material name="orange">
        <color rgba="1.0 0.4 0.04 1.0"/>
    </material>

<!-- ############# Define Link & Joint ############# -->

    <!-- Origin -->
    <link name="cs_ground"/>

    <joint name="lower_body_joint" type="fixed">
        <parent link="cs_ground"/>
        <child link="base_link"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 1.0670"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_Lower.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="dark"/>
        </visual>
    </link>

    <!-- Swing joint -->
    <joint name="upper_body_joint" type="revolute">
        <parent link="base_link"/>
        <child link="cs_cor"/>
        <origin rpy="0 0 0" xyz="0 0 1.0670"/>
        <axis xyz="0 0 1"/>
        <limit lower="-100000" upper="100000" velocity="0.1" effort="100"/>
    </joint>

    <link name="cs_cor">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_Body.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <joint name="cover_a_joint" type="fixed">
        <parent link="cs_cor"/>
        <child link="cover_a"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <link name="cover_a">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_CoverA.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
    </link>

    <joint name="cover_b_joint" type="fixed">
        <parent link="cs_cor"/>
        <child link="cover_b"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <link name="cover_b">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_CoverB.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <!-- Boom joint -->
    <joint name="boom_joint" type="revolute">
        <parent link="cs_cor"/>
        <child link="cs_boom"/>
        <origin rpy="0 1.07374 0" xyz="0.117 -0.06 0.738"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-0.59" upper="1.39" velocity="0.1" effort="100"/>
    </joint>

    <link name="cs_boom">
        <visual>
            <origin rpy="0 0 0" xyz="-0.117 0.06 -0.738"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_Boom.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
    </link>

    <!-- ARM joint -->
    <joint name="arm_joint" type="revolute">
        <parent link="cs_boom"/>
        <child link="cs_arm"/>
        <origin rpy="0 -2.7182 0" xyz="2.718 0 5.0103"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-2.8" upper="-0.65" velocity="0.1" effort="100"/>
    </joint>

    <link name="cs_arm">
        <visual>
            <origin rpy="0 0 0" xyz="-2.835 0.06 -5.7483"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_Arm.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <!-- Bucket joint -->
    <joint name="bucket_joint" type="revolute"> <!-- Point D -->
        <parent link="cs_arm"/>
        <child link="cs_bucket"/>
        <origin rpy="0 0.075 0" xyz="-0.2142 0 -2.9029"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-2.495" upper="0.75" velocity="0.1" effort="100"/>
    </joint>

    <link name="cs_bucket"> <!-- Link DT -->
        <visual>
            <origin rpy="1.5707 0 -1.5707" xyz="0.15 0 -0.2"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_TR_Upper.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="dark"/>
        </visual>
    </link>

    <!-- Tilt joint -->
    <joint name="tilt_joint" type="revolute"> <!-- Point T -->
        <parent link="cs_bucket"/>
        <child link="cs_tilt"/>
        <origin rpy="0 -1.5707963267948966 0" xyz="0 0 -0.5548"/>
        <axis xyz="0 0 1"/>
        <!-- <limit lower="-0.7" upper="0.7" velocity="0.1" effort="100"/> -->
        <!-- set conservative limit for stable tilt joint control -->
        <limit lower="-0.27" upper="0.27" velocity="0.1" effort="100"/>
    </joint>

    <link name="cs_tilt"> <!-- Link TU -->
        <visual>
            <!-- <origin rpy="3.141592653589793 -1.5707963267948966 0" xyz="-0.1 0 -0.5128"/> -->
            <origin rpy="3.141592653589793 -1.5707963267948966 0" xyz="0 0 -0.47"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_TR_Mid.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="dark"/>
        </visual>
    </link>

    <!-- Rotate joint -->
    <joint name="rotate_joint" type="revolute"> <!-- Point U -->
        <parent link="cs_tilt"/>
        <child link="cs_rotate"/>
        <!-- <origin rpy="3.141592653589793 -1.5707963267948966 0" xyz="-0.1 0 -0.5128"/> -->
        <origin rpy="3.141592653589793 -1.5707963267948966 0" xyz="0.0 0 -0.47"/>
        <axis xyz="0 0 1" />
        <limit lower="-100000" upper="100000" velocity="0.1" effort="100"/>
    </joint>

    <link name="cs_rotate"> <!-- Link UV -->
        <visual>
            <origin rpy="0 0 0" xyz="0 0 -0.105"/>
            <geometry>
                <mesh filename="assets/excavator_3/EX_CX_TR_Lower.stl" scale="1 1 1"/>
            </geometry>
            <material name="dark"/>
        </visual>
    </link>

    <!-- Grip body joint -->
    <joint name="Gripbody_joint" type="fixed"> 
        <parent link="cs_rotate"/>
        <child link="grip_body"/>
        <origin rpy="-1.555796 0 -1.570796" xyz="0.009 0 -0.529" />      
    </joint>

    <link name="grip_body"> 
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="assets/excavator_3/StoneGrab_Body.stl" scale="1 1 1"/>
            </geometry>
            <material name="dark"/>
        </visual>
    </link>

    <!-- Grip Left joint -->
    <joint name="Gripleft_joint" type="revolute"> 
        <parent link="grip_body"/>
        <child link="grip_left"/>
	<origin rpy="0 0 0" xyz="-0.375 0.257 0.0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-1.14" upper="0" velocity="0.1" effort="100"/>
    </joint>

    <link name="grip_left"> 
        <visual>
            <origin rpy="0 0 0" xyz="0.375 -0.257 0.0"/>
            <geometry>
                <mesh filename="assets/excavator_3/StoneGrab_Left_with_Teeth.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="dark"/>
        </visual>
    </link>

    <!-- Grip Right joint -->
    <joint name="Gripright_joint" type="revolute"> 
        <parent link="grip_body"/>
        <child link="grip_right"/>
        <origin rpy="0 0 0" xyz="0.375 0.257 0.0"/>
        <axis xyz="0 0 -1"/>
        <limit lower="-1.14" upper="0" velocity="0.1" effort="100"/>
    </joint>

    <link name="grip_right"> 
        <visual>
            <origin rpy="0 0 0" xyz="-0.375 -0.257 0.0"/>
            <geometry>
                <mesh filename="assets/excavator_3/StoneGrab_Right_with_Teeth.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="dark"/>
        </visual>
    </link>


<!-- ################### Sensor setting ################### -->

    <joint name="boom_to_lidar_joint" type="fixed">
        <parent link="cs_boom"/>
        <child link="boom_to_lidar_link"/>
        <origin rpy="0 -1.07374 0" xyz="0.0 0.0 0.0"/>
    </joint>

    <link name="boom_to_lidar_link"/>

    <joint name="arm_to_lidar_joint" type="fixed">
        <parent link="cs_arm"/>
        <child link="arm_to_lidar_link"/>
        <origin rpy="0 1.6445 0" xyz="0.0 0.0 0.0"/>
    </joint>

    <link name="arm_to_lidar_link"/>

    <!-- Lidar1 joint -->
    <joint name="lidar1_joint" type="fixed">
        <parent link="boom_to_lidar_link"/>
        <child link="lidar1_link"/>
        <origin rpy="0.0 1.79336 0.0" xyz="3.6656 0.3265 0.2631"/>
    </joint>

    <link name="lidar1_link"/>

    <!-- Lidar2 joint -->
    <joint name="lidar2_joint" type="fixed">
        <parent link="boom_to_lidar_link"/>
        <child link="lidar2_link"/>
        <origin rpy="0 1.008 0" xyz="3.8917 0.2431 0.2585"/>
        <!-- <origin rpy="-0.02862335 0.9225526 -0.03061285" xyz="3.642763 0.31894395 0.00691766"/> -->
    </joint>

    <link name="lidar2_link"/>

    <!-- Lidar3 joint -->
    <joint name="lidar3_joint" type="fixed">
        <parent link="arm_to_lidar_link"/>
        <child link="lidar3_link"/>
        <origin rpy="3.141592653589793 0.3640 0.0" xyz="1.8705925267480394 0.35064 -0.047676397456024165"/>
    </joint>

    <link name="lidar3_link"/>

</robot>

