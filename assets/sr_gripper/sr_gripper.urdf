<?xml version="1.0"?>
<robot name="sr_gripper_custom">
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="meshes/visual/link0.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/collision/link0.obj"/>
      </geometry>
    </collision>
  </link>

  <link name="left_finger_link_1">
    <visual>
      <geometry>
        <mesh filename="meshes/visual/link1.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/collision/link1.obj"/>
      </geometry>
    </collision>
  </link>

  <link name="left_finger_link_2">
    <visual>
      <geometry>
        <mesh filename="meshes/visual/link2.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/collision/link2.obj"/>
      </geometry>
    </collision>
  </link>

  <link name="right_finger_link_1">
    <visual>
      <geometry>
        <mesh filename="meshes/visual/link1.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/collision/link1.obj"/>
      </geometry>
    </collision>
  </link>

  <link name="right_finger_link_2">
    <visual>
      <origin xyz="0 0.015 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/visual/link2.obj"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 -0.015 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/visual/link2.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0.015 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/collision/link2.obj"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.015 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/collision/link2.obj"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_finger_joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="left_finger_link_1"/>
    <origin xyz="0.03 0 0.11" rpy="0 0 3.141592653589793"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.9"/>
  </joint>

  <joint name="left_finger_joint_2" type="revolute">
    <parent link="left_finger_link_1"/>
    <child link="left_finger_link_2"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.9" upper="0.0"/>
    <mimic joint="left_finger_joint_1" multiplier="-1" offset="0"/>
  </joint>

  <joint name="right_finger_joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="right_finger_link_1"/>
    <origin xyz="-0.03 0 0.11" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.9"/>
    <mimic joint="left_finger_joint_1" multiplier="1" offset="0"/>
  </joint>

  <joint name="right_finger_joint_2" type="revolute">
    <parent link="right_finger_link_1"/>
    <child link="right_finger_link_2"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.9" upper="0.0"/>
    <mimic joint="left_finger_joint_1" multiplier="-1" offset="0"/>
  </joint>
</robot>
