<?xml version="1.0"?>

<robot name="StoneGrab" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- Predefine Colors -->
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>

    <material name="dark">
        <color rgba="0.2 0.2 0.2 1.0"/>
    </material>

    <material name="dark_grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
    </material>

    <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
    </material>

    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
    </material>

    <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
    </material>

    <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
    </material>

    <material name="orange">
        <color rgba="1.0 0.4 0.04 1.0"/>
    </material>

<!-- ############# Define Link & Joint ############# -->

    <!-- Origin -->
    <link name="cs_ground"/>

    <joint name="grip_body_joint" type="floating">
        <parent link="cs_ground"/>
        <child link="grip_body"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <link name="grip_body"> 
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="assets/stone_grab_2/StoneGrab_Body.stl" scale="1 1 1"/>
            </geometry>
            <material name="dark"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Body_dsf.obj" contact="true"/>
            </geometry>
            <material name="dark"/>
        </collision>
    </link>

    <!-- Grip Left joint -->
    <joint name="Gripleft_joint" type="revolute"> 
        <parent link="grip_body"/>
        <child link="grip_left"/>
	<origin rpy="0 0 0" xyz="-0.375 0.257 0.0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-1.14" upper="0" velocity="0.1" effort="100"/>
    </joint>

    <link name="grip_left"> 
        <visual>
            <origin rpy="0 0 0" xyz="0.375 -0.257 0.0"/>
            <geometry>
                <mesh filename="assets/stone_grab_2/StoneGrab_Left_with_Teeth.stl" scale="100.0 100.0 100.0"/>
            </geometry>
            <material name="dark"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Left_dsf1.obj" contact="false"/>
            </geometry>
            <material name="dark"/>
        </collision>
        <collision name="tip">
            <origin rpy="0 0 0" xyz="0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Left_dsf2.obj" contact="true"/>
            </geometry>
            <material name="dark"/>
        </collision>
        <collision name="teeth">
            <origin rpy="0 0 0" xyz="0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Left_Teeth_dsf1.obj" contact="true"/>
            </geometry>
            <material name="dark"/>
        </collision>               
        <collision name="teeth">
            <origin rpy="0 0 0" xyz="0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Left_Teeth_dsf2.obj" contact="true"/>
            </geometry>
            <material name="dark"/>
        </collision>               
    </link>

    <!-- Grip Right joint -->
    <joint name="Gripright_joint" type="revolute"> 
        <parent link="grip_body"/>
        <child link="grip_right"/>
        <origin rpy="0 0 0" xyz="0.375 0.257 0.0"/>
        <axis xyz="0 0 -1"/>
        <limit lower="-1.14" upper="0" velocity="0.1" effort="100"/>
    </joint>

    <link name="grip_right"> 
        <visual>
            <origin rpy="0 0 0" xyz="-0.375 -0.257 0.0"/>
            <geometry>
                <mesh filename="assets/stone_grab_2/StoneGrab_Right_with_Teeth.stl" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name="dark"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Right_dsf1.obj" contact="false"/>
            </geometry>
            <material name="dark"/>
        </collision>      
        <collision name="tip">
            <origin rpy="0 0 0" xyz="-0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Right_dsf2.obj" contact="true"/>
            </geometry>
            <material name="dark"/>
        </collision>      
        <collision name="teeth">
            <origin rpy="0 0 0" xyz="-0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Right_Teeth_dsf1.obj" contact="true"/>
            </geometry>
            <material name="dark"/>
        </collision>          
        <collision name="teeth">
            <origin rpy="0 0 0" xyz="-0.375 -0.257 0.0"/>
            <geometry>
                <dsf_vert filename="assets/stone_grab_2/StoneGrab_Right_Teeth_dsf2.obj" contact="true"/>
            </geometry>
            <material name="dark"/>
        </collision>         
    </link>

</robot>

